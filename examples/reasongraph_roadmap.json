  {
   "id": "F-BLOCK-ONEHOP",
   "kind": "finding",
   "title": "Block propagation is one-hop, not transitive (grandchild of a refuted node = AWAITING)",
   "statement": "Verified by reproduction: deduction() inspects only immediate prerequisites, so a refutation blocks children but not grandchildren. A real TMS relabels the whole reachable subgraph.",
   "status": "proven",
   "confidence": 0.5,
   "attrs": {
    "payoff": 0.5,
    "effort": 0.5,
    "tractability": 0.5,
    "readiness": 0.5,
    "strategic_fit": 0.5,
    "info_value": 0.8,
    "risk": 0.3
   },
   "evidence": [
    "reproduction 2026-06: P refuted, C blocked, GC awaiting",
    "docs/RESEARCH-NOTES.md \u00a73"
   ],
   "frontier": false
  },
